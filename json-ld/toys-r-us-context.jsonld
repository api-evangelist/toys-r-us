{
  "@context": {
    "@vocab": "https://schema.org/",
    "toys-r-us": "https://api-evangelist.com/context/toys-r-us/",
    "lb": "https://api-evangelist.com/context/logicbroker/",
    "Order": "schema:Order",
    "key": "lb:documentKey",
    "PartnerPO": "schema:orderNumber",
    "OrderDate": "schema:orderDate",
    "Status": "lb:documentStatus",
    "ShipToAddress": "schema:deliveryAddress",
    "Name": "schema:name",
    "Address1": "schema:streetAddress",
    "Address2": "lb:streetAddressLine2",
    "City": "schema:addressLocality",
    "State": "schema:addressRegion",
    "Zip": "schema:postalCode",
    "Country": "schema:addressCountry",
    "LineItems": "schema:orderedItem",
    "LineNumber": "lb:lineNumber",
    "SupplierSKU": "toys-r-us:supplierSKU",
    "BuyerSKU": "toys-r-us:buyerSKU",
    "UPC": "schema:gtin12",
    "Description": "schema:description",
    "Quantity": "schema:orderQuantity",
    "UnitPrice": "schema:price",
    "UOM": "lb:unitOfMeasure",
    "Shipment": "schema:ParcelDelivery",
    "TrackingNumber": "schema:trackingNumber",
    "Carrier": "schema:hasDeliveryMethod",
    "ShipDate": "schema:expectedArrivalFrom",
    "Package": "lb:package",
    "Weight": "schema:weight",
    "Invoice": "schema:Invoice",
    "InvoiceNumber": "schema:confirmationNumber",
    "InvoiceDate": "schema:dateIssued",
    "Product": "schema:Product",
    "MSRP": "schema:suggestedRetailPrice",
    "InStock": "schema:itemAvailability"
  }
}
